{
  "version": 2,
  "builds": [
    {
      "src": "apps/backend/src/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "apps/backend/src/index.js"
    }
  ],
  "crons": [
    { "path": "/api/cron/morning", "schedule": "0 2 * * *" },
    { "path": "/api/cron/afternoon", "schedule": "0 8 * * 1-5" },
    { "path": "/api/cron/evening", "schedule": "0 13 * * *" },
    { "path": "/api/cron/summary-reminder", "schedule": "0 16 * * *" },
    { "path": "/api/cron/streak-reset", "schedule": "1 17 * * *" }
  ]
}
